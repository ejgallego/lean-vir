package lean:vir;

interface runtime {
  record package-info {
    decls: u32,
    bytes: u32,
    interface-exports: u32,
  }

  record call-request {
    entry: string,
    payload: list<u8>,
    result-wire-tag: u8,
  }

  record call-output {
    payload: list<u8>,
  }

  load-package: func(bytes: list<u8>) -> result<package-info, string>;
  interface-manifest: func() -> result<string, string>;
  call: func(request: call-request) -> result<call-output, string>;
}

world runner {
  export runtime;
}
