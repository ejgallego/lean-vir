{
  "version": 1,
  "defaultPackage": "fixtures-basic",
  "hostPackage": "demo-host",
  "packages": [
    {
      "id": "fixtures-basic",
      "file": "fixtures-basic.irpkg",
      "label": "Basic, list/option, interface shapes",
      "report": "build/generated/fixtures-basic.report.md",
      "targets": [
        {
          "source": "examples/Fib.lean",
          "roots": ["fib"]
        },
        {
          "source": "examples/MergeSort.lean",
          "roots": ["SortDemo.demo", "SortDemo.demoFromArray"]
        },
        {
          "source": "fixtures/Basic.lean",
          "roots": [
            "Vir.Fixtures.Basic.stringUtf8RoundtripScore",
            "Vir.Fixtures.Basic.byteArrayInputScore"
          ]
        },
        {
          "source": "fixtures/RecursiveTypes.lean",
          "roots": [
            "Vir.Fixtures.RecursiveTypes.treeRootScore",
            "Vir.Fixtures.RecursiveTypes.chainRootScore",
            "Vir.Fixtures.RecursiveTypes.jsonRootScore"
          ]
        }
      ],
      "fixtureSources": [
        "fixtures/Basic.lean",
        "fixtures/ListOption.lean",
        "fixtures/InterfaceShapes.lean",
        "fixtures/RecursiveTypes.lean"
      ]
    },
    {
      "id": "demo-host",
      "file": "demo-host.irpkg",
      "label": "Browser host calls, React, and Tamagotchi demos",
      "report": "build/generated/demo-host.report.md",
      "targets": [
        {
          "source": "examples/HostInterop.lean",
          "roots": [
            "HostInterop.titleHandshake",
            "HostInterop.titleHandshakeLoop",
            "HostInterop.callbackRoundTrip",
            "HostInterop.callbackRoundTripLoop",
            "HostInterop.mountCallbackEvent",
            "HostInterop.mountAndRemoveCallbackEvent",
            "HostInterop.mountAndRemoveCallbackEventLoop",
            "HostInterop.mountCallbackText",
            "HostInterop.mountAndRemoveCallbackText",
            "HostInterop.timeoutRecord",
            "HostInterop.timeoutTitle",
            "HostInterop.delayedTimeoutTitle",
            "HostInterop.clearTimeoutTitle",
            "HostInterop.clearTimeoutRecord",
            "HostInterop.startTimeoutLoop",
            "HostInterop.animationRecord",
            "HostInterop.animationTitle",
            "HostInterop.cancelAnimationTitle",
            "HostInterop.cancelAnimationRecord",
            "HostInterop.startAnimationLoop"
          ]
        },
        {
          "source": "examples/Tamagotchi.lean",
          "roots": [
            "Tamagotchi.uiReset",
            "Tamagotchi.uiResetFromDom",
            "Tamagotchi.uiMountFromDom",
            "Tamagotchi.uiRenameFromDom",
            "Tamagotchi.uiStep",
            "Tamagotchi.uiStepFromDom",
            "ReactTamagotchi.mount",
            "ReactTamagotchi.mountDefault"
          ]
        },
        {
          "source": "examples/ReactCounter.lean",
          "roots": [
            "ReactCounter.mount",
            "ReactCounter.mountDefault",
            "ReactCounter.renderStatic",
            "ReactCounter.renderWideTextLoop",
            "ReactCounter.renderCallbackTreeLoop",
            "ReactCounter.mountAndUnmount",
            "ReactCounter.mountAndUnmountLoop",
            "ReactCounter.renderAfterUnmount",
            "ReactCounter.renderTooDeep"
          ]
        },
        {
          "source": "examples/ReactInput.lean",
          "roots": [
            "ReactInput.mountInput",
            "ReactInput.mountChangeInput",
            "ReactInput.mountCheckbox",
            "ReactInput.mountAttributes"
          ]
        }
      ],
      "fixtureSources": []
    },
    {
      "id": "pretty-printer",
      "file": "pretty-printer.irpkg",
      "label": "Std.Format.pretty component package",
      "report": "build/generated/pretty-printer.report.md",
      "targets": [
        {
          "source": "fixtures/FormatPretty.lean",
          "roots": [
            "Vir.Fixtures.FormatPretty.formatPrettyPreview",
            "Vir.Fixtures.FormatPretty.formatPrettyAtWidth",
            "Vir.Fixtures.FormatPretty.formatPrettyCaseAtWidth"
          ]
        }
      ],
      "fixtureSources": ["fixtures/FormatPretty.lean"]
    },
    {
      "id": "fixtures-lean",
      "file": "fixtures-lean.irpkg",
      "label": "Lean Expr, parser, Task",
      "report": "build/generated/fixtures-lean.report.md",
      "targets": [],
      "fixtureSources": [
        "fixtures/ExprPrinter.lean",
        "fixtures/LeanParser.lean",
        "fixtures/LeanParserHeader.lean",
        "fixtures/Task.lean"
      ]
    },
    {
      "id": "fixtures-boundary",
      "file": "fixtures-boundary.irpkg",
      "label": "Numeric and runtime boundaries",
      "report": "build/generated/fixtures-boundary.report.md",
      "targets": [],
      "fixtureSources": ["fixtures/Boundary.lean"]
    }
  ],
  "localPackages": [
    {
      "file": "local-quickstart.irpkg",
      "label": "Four small exports from one Lean file"
    },
    {
      "file": "local-fib.irpkg",
      "label": "Focused fib package"
    },
    {
      "file": "local-mergesort.irpkg",
      "label": "Focused mergesort package"
    }
  ]
}
