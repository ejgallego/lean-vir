{
  "name": "lean-vir",
  "version": "0.1.0",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "fetch:lean": "bash scripts/fetch-lean-source.sh",
    "install:wasi": "bash scripts/install-wasi-sdk.sh",
    "install:engines": "bash scripts/install-wasm-engines.sh",
    "generate:package": "bash scripts/generate-ir-package.sh",
    "generate:provider": "npm run generate:package",
    "check:package": "bash scripts/check-demo-package.sh",
    "check:boundary-registry": "node scripts/check-boundary-registry.mjs",
    "probe:upstream": "bash scripts/build-upstream-probe.sh",
    "build": "npm run build:demo",
    "build:demo": "npm run probe:upstream",
    "build:site": "npm run build:demo && vite build web --base /lean-vir/",
    "bench": "node scripts/bench-vir.mjs",
    "bench:engines": "node scripts/bench-engines.mjs",
    "test": "npm run check:boundary-registry && npm run test:upstream && npm run test:fixtures",
    "test:fixtures": "node scripts/run-fixtures.mjs",
    "test:upstream": "npm run build:demo && node scripts/smoke_upstream.mjs",
    "dev": "vite web --host 127.0.0.1"
  },
  "devDependencies": {
    "vite": "^8.0.13"
  }
}
